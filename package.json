{
  "name": "shipit-cli",
  "version": "0.1.1",
  "description": "A safe AI-assisted Git shipping CLI for commits, pushes, and pull requests.",
  "type": "module",
  "bin": {
    "shipit": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "install.sh"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "keywords": [
    "git",
    "cli",
    "openrouter",
    "commit",
    "pull-request"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.12.24",
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "minimatch": "^10.0.1",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
